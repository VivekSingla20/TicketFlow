# Server
NODE_ENV=development
PORT=3000
WORKER_CONCURRENCY=10

# Database
DATABASE_URL=postgresql://ticketuser:ticketpass@localhost:5432/ticketdb

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
REFRESH_COOKIE_SECRET=your-cookie-secret-change-in-production

# Reservation
RESERVATION_TTL_MINUTES=10

# Payment Mock
MOCK_PAYMENT_WEBHOOK_SECRET=mock-payment-webhook-secret
MOCK_PAYMENT_SUCCESS_RATE=0.95
MOCK_PAYMENT_DELAY_MS_MIN=200
MOCK_PAYMENT_DELAY_MS_MAX=1200

# Rate Limiting
RATE_LIMIT_GLOBAL_MAX=500
RATE_LIMIT_GLOBAL_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# WebSocket
WS_CORS_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:3000
